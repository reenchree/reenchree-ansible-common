{# Managed by Ansible (reenchree.common.nut_server) — do not edit manually #}
{# upsd.users semantics: `actions` and `instcmds` may appear multiple times
   per user (NUT merges them additively). The `upsmon primary|secondary`
   line uses no `=` per NUT's parser. #}
{% for user in nut_server_users %}
[{{ user.name }}]
  password = {{ user.password }}
{%   for action in user.actions | default([]) %}
  actions = {{ action }}
{%   endfor %}
{%   for instcmd in user.instcmds | default([]) %}
  instcmds = {{ instcmd }}
{%   endfor %}
{%   if user.upsmon is defined %}
  upsmon {{ user.upsmon }}
{%   endif %}
{% endfor %}
